# Django
SECRET_KEY=change-me-in-production
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.docker

# PostgreSQL
POSTGRES_DB=oyra
POSTGRES_USER=oyra
POSTGRES_PASSWORD=strong-password
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgres://oyra:strong-password@db:5432/oyra

# Domain (замініть your-domain.com на реальний домен)
DOMAIN=your-domain.com
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,DROPLET_IP,127.0.0.1,localhost,web
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
USE_HTTPS=false
SITE_URL=http://DROPLET_IP
SECURE_SSL_REDIRECT=False

# LiqPay
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SERVER_URL=
LIQPAY_SANDBOX=False

# Nova Poshta
NOVA_POSHTA_API_KEY=

# Email (optional)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@oyra.ua

# Docker compose
HTTP_PORT=80
